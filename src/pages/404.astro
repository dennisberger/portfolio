---
import Base from '@/layouts/Base.astro';
---

<Base title="404 — Dennis Berger" description="Page not found." noindex>
  <section class="lost page">
    <p class="lost__kicker">404</p>
    <h1 class="lost__title">But why?</h1>
    <p class="lost__body">
      I did everything right. Okay — calm down. Did you commit your changes? Are you browsing the local copy?
    </p>
    <div class="lost__actions">
      <a href="/" class="btn btn--primary">Home</a>
      <a href="/#work" class="btn btn--ghost">Case studies</a>
    </div>
    <p class="lost__footnote">
      If this is my fault, <a href="/contact/">let me know</a> — it'll nag at me until I fix it.
    </p>
  </section>
</Base>

<style>
  .lost {
    padding-block: var(--space-section-hero);
    max-width: 40rem;
    text-align: left;
  }
  .lost__kicker {
    font-family: var(--font-display);
    font-size: clamp(6rem, 18vw, 14rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-fuchsia);
    line-height: 0.9;
    letter-spacing: -0.06em;
    margin-block-end: var(--space-sm);
    margin-inline-start: -0.04em;
  }
  .lost__title {
    margin-block-end: var(--space-lg);
  }
  .lost__body {
    font-family: var(--font-body);
    font-size: var(--type-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-ink-muted);
    margin-block-end: var(--space-xl);
  }
  .lost__actions { display: flex; gap: var(--space-md); margin-block-end: var(--space-xl); flex-wrap: wrap; }
  .lost__footnote {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
