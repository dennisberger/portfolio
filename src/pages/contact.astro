---
import Base from '@/layouts/Base.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import MarginNote from '@/components/MarginNote.astro';

const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY ?? '';
---

<Base
  title="Contact — Dennis Berger"
  description="Send a note. Opportunities, questions, or DesignOps conversations welcome."
>
  <section class="contact page">
    <SectionLabel>Contact</SectionLabel>
    <h1 class="contact__title">Send a note.</h1>
    <p class="contact__lede">Fastest way to reach me. I write back.</p>
    <MarginNote>DesignOps questions, side-project trades, Philly food recs (actually, any food recs) are all welcome.</MarginNote>

    <div class="contact__card">
      <p class="form__required-note">All fields required.</p>

      <noscript>
        <p class="form__noscript">
          This form needs JavaScript. If yours is off, reach me on
          <a href="https://linkedin.com/in/dennisberger" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          instead.
        </p>
      </noscript>

      <form id="contact-form" class="form" action="/api/contact" method="POST" novalidate>
        <label class="field">
          <span class="field__label">Your name</span>
          <input
            type="text"
            name="name"
            id="field-name"
            required
            maxlength="200"
            autocomplete="name"
            aria-describedby="field-name-error"
          />
          <span class="field__error" id="field-name-error" hidden></span>
        </label>

        <label class="field">
          <span class="field__label">Email</span>
          <input
            type="email"
            name="email"
            id="field-email"
            required
            maxlength="254"
            autocomplete="email"
            aria-describedby="field-email-error"
          />
          <span class="field__error" id="field-email-error" hidden></span>
        </label>

        <label class="field">
          <span class="field__label">Message</span>
          <textarea
            name="message"
            id="field-message"
            rows="6"
            required
            minlength="10"
            maxlength="5000"
            aria-describedby="field-message-hint field-message-error"
          ></textarea>
          <span class="field__hint" id="field-message-hint">A sentence or two is plenty.</span>
          <span class="field__error" id="field-message-error" hidden></span>
        </label>

        <div class="field field--honeypot" aria-hidden="true">
          <span class="field__label">Website</span>
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
        </div>

        {TURNSTILE_SITE_KEY && (
          <div class="form__turnstile">
            <div
              class="cf-turnstile"
              data-sitekey={TURNSTILE_SITE_KEY}
              data-appearance="interaction-only"
              data-theme="auto"
              data-size="flexible"
            ></div>
          </div>
        )}

        <div class="form__actions">
          <button type="submit" class="btn btn--primary" id="form-submit">Send it</button>
          <p class="form__helper">
            Or find me on <a href="https://linkedin.com/in/dennisberger" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
          </p>
        </div>

        <p class="form__status" role="status" aria-live="polite" hidden id="form-status"></p>
        <p class="form__status form__status--error" role="alert" aria-live="assertive" hidden id="form-alert"></p>
      </form>
    </div>
  </section>
</Base>

{TURNSTILE_SITE_KEY && (
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
)}

<script>
  type FieldName = 'name' | 'email' | 'message';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;
  const alertRegion = document.getElementById('form-alert') as HTMLParagraphElement | null;
  const submit = document.getElementById('form-submit') as HTMLButtonElement | null;

  const fieldInputIds: Record<FieldName, string> = {
    name: 'field-name',
    email: 'field-email',
    message: 'field-message',
  };
  const fieldErrorIds: Record<FieldName, string> = {
    name: 'field-name-error',
    email: 'field-email-error',
    message: 'field-message-error',
  };

  const clearFieldErrors = () => {
    (Object.keys(fieldInputIds) as FieldName[]).forEach((f) => {
      const input = document.getElementById(fieldInputIds[f]) as HTMLInputElement | HTMLTextAreaElement | null;
      const err = document.getElementById(fieldErrorIds[f]) as HTMLSpanElement | null;
      if (input) input.removeAttribute('aria-invalid');
      if (err) { err.hidden = true; err.textContent = ''; }
    });
  };

  const markFieldError = (field: FieldName, message: string) => {
    const input = document.getElementById(fieldInputIds[field]) as HTMLInputElement | HTMLTextAreaElement | null;
    const err = document.getElementById(fieldErrorIds[field]) as HTMLSpanElement | null;
    if (input) {
      input.setAttribute('aria-invalid', 'true');
      input.focus();
    }
    if (err) {
      err.textContent = message;
      err.hidden = false;
    }
  };

  if (form && status && alertRegion) {
    // Two always-present regions: polite status + assertive alert.
    // Announcing via the right channel beats toggling one element's role
    // mid-lifecycle (historically flaky in NVDA/JAWS).
    const setStatus = (variant: 'sending' | 'success' | 'error', text: string) => {
      if (variant === 'error') {
        alertRegion.hidden = false;
        alertRegion.textContent = text;
        alertRegion.className = 'form__status form__status--error';
        status.hidden = true;
        status.textContent = '';
      } else {
        status.hidden = false;
        status.textContent = text;
        status.className = `form__status form__status--${variant}`;
        alertRegion.hidden = true;
        alertRegion.textContent = '';
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearFieldErrors();
      if (submit) {
        submit.disabled = true;
        submit.textContent = 'Sending…';
      }
      setStatus('sending', 'Sending…');

      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error?: string;
          field?: FieldName;
        };

        if (res.ok && data.ok) {
          form.reset();
          setStatus('success', "Got it. A confirmation email is on its way, and I'll write back soon.");
        } else {
          const message = data.error ?? 'Something broke. Try LinkedIn, or refresh and retry.';
          setStatus('error', message);
          if (data.field && data.field in fieldInputIds) {
            markFieldError(data.field, message);
          }
        }
      } catch {
        setStatus('error', 'Something broke. Try LinkedIn, or refresh and retry.');
      } finally {
        if (submit) {
          submit.disabled = false;
          submit.textContent = 'Send it';
        }
      }
    });
  }
</script>

<style>
  .contact {
    padding-block: var(--space-section-hero) var(--space-section);
    max-width: var(--col-total);
  }
  /* Reserve a right gutter at desktop so MarginNote floats into it. */
  @media (min-width: 1080px) {
    .contact { padding-right: calc(var(--col-gutter) + var(--col-gap)); }
  }

  .contact__title {
    font-size: var(--type-4xl);
    margin-block: var(--space-md) var(--space-md);
  }

  .contact__lede {
    font-family: var(--font-body);
    font-size: var(--type-lg);
    color: var(--color-ink-muted);
    margin-block-end: var(--space-xl);
  }


  /* Contact card: editorial rule-delimited band, matching the site's paper +
     hairline chassis. No gradient, no shadow, no rounded border. */
  .contact__card {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .form__required-note {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0 0 var(--space-md);
  }

  .form__noscript {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    padding: var(--space-sm) var(--space-md);
    margin: 0 0 var(--space-md);
    border-inline-start: 2px solid var(--color-fuchsia);
    background: var(--color-fuchsia-soft);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .form[hidden] {
    display: none;
  }

  .field { display: flex; flex-direction: column; gap: var(--space-xs); }

  .field--honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .field__label {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
  }
  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: var(--type-base);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-paper-raised);
    color: var(--color-ink);
    border: 1px solid var(--color-ink-dim);
    border-radius: var(--radius-xs);
    resize: vertical;
    transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }

  .field textarea { min-height: 11rem; }

  .field input:hover,
  .field textarea:hover {
    border-color: color-mix(in oklch, var(--color-cobalt-deep) 55%, var(--color-ink-dim));
  }

  .field input:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-fuchsia);
    outline-offset: 2px;
    border-color: var(--color-fuchsia);
    box-shadow: 0 0 0 4px color-mix(in oklch, var(--color-fuchsia-soft) 65%, transparent);
  }

  .field input[aria-invalid='true'],
  .field textarea[aria-invalid='true'] {
    border-color: var(--color-fuchsia-deep);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-fuchsia-soft) 75%, transparent);
  }

  .field__hint {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    color: var(--color-ink-muted);
    font-style: italic;
    margin-block-start: var(--space-2xs);
  }

  .field__error {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 500;
    color: var(--color-fuchsia-deep);
    margin-block-start: var(--space-2xs);
  }

  .field__error[hidden] { display: none; }

  /* Turnstile in interaction-only mode: no wrapper chrome. The widget needs
     a laid-out container to render its iframe into, even when it stays
     visually silent — so no display:none tricks here.  */
  .form__turnstile .cf-turnstile iframe {
    max-width: 100%;
  }

  .form__actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-block-start: var(--space-sm);
  }
  .form__helper {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .form__status {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-xs);
  }

  .form__status[hidden] {
    display: none;
  }

  .form__status--sending { color: var(--color-ink-muted); }
  .form__status--success {
    color: var(--color-cobalt-deep);
    background: var(--color-cobalt-soft);
  }
  .form__status--error {
    color: var(--color-fuchsia-deep);
    background: var(--color-fuchsia-soft);
  }

  @media (max-width: 640px) {
    .form__actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
