      type="button"
      class="nav__close"
      aria-label="Close menu"
      data-nav-close
    >
      <span aria-hidden="true">×</span>
    </button>

    <div class="nav__overlay-inner">
      <ul class="nav__overlay-primary">
        {primary.map(i => (
          <li>
            <a
              href={i.href}
              aria-current={current.startsWith(i.href) ? 'page' : undefined}
            >{i.label}</a>
          </li>
        ))}
      </ul>

      <ul class="nav__overlay-secondary">
        {secondary.map(i => (
          <li>
            <a
              href={i.href}
              {...(i.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >{i.label}</a>
          </li>
        ))}
      </ul>

      <div class="nav__overlay-theme"><ThemeToggle /></div>
    </div>
  </div>
</nav>

<script>
  const trigger = document.querySelector('[data-nav-trigger]') as HTMLButtonElement | null;
  const overlay = document.querySelector('[data-nav-overlay]') as HTMLDivElement | null;
  const close = document.querySelector('[data-nav-close]') as HTMLButtonElement | null;

  if (trigger && overlay && close) {
    let lastFocused: HTMLElement | null = null;

    // Siblings that should be inert while the dialog is open — prevents
    // VoiceOver/NVDA rotor from reaching background content behind the modal.
    const inertTargets = (): (HTMLElement | null)[] => [
      document.getElementById('main'),
      document.querySelector<HTMLElement>('.footer'),
      document.querySelector<HTMLElement>('.nav__inner'),
    ];

    const focusables = () => Array.from(
      overlay.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
    );

    const open = () => {
      lastFocused = document.activeElement as HTMLElement;
      overlay.hidden = false;
      // Force reflow so the transition applies from the [hidden]-removed state.
      void overlay.offsetHeight;
      overlay.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      document.documentElement.classList.add('nav-overlay-open');
      // Hide background content from assistive tech.
      inertTargets().forEach((el) => el?.setAttribute('inert', ''));
      // Move focus to the close button so ESC / Return work immediately.
      close.focus();
    };

    const shut = () => {
      overlay.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      document.documentElement.classList.remove('nav-overlay-open');
      // Restore background reachability for AT.
      inertTargets().forEach((el) => el?.removeAttribute('inert'));
      // Wait for the fade-out transition, then hide from AT.
      const finish = () => {
        overlay.hidden = true;
        overlay.removeEventListener('transitionend', finish);
      };
      // Respect reduced-motion: no transition, hide immediately.
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
        overlay.hidden = true;
      } else {
        overlay.addEventListener('transitionend', finish);
      }
      lastFocused?.focus?.();
    };

    trigger.addEventListener('click', open);
    close.addEventListener('click', shut);

    // Any link click closes (same-origin nav triggers a full page load anyway).
    overlay.querySelectorAll('a[href]').forEach((link) => {
      link.addEventListener('click', shut);
    });

    // Escape closes. Tab/Shift-Tab focus trap.
    document.addEventListener('keydown', (e) => {
      if (overlay.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        shut();
        return;
      }
      if (e.key === 'Tab') {
        const list = focusables();
        if (!list.length) return;
        const first = list[0];
        const last = list[list.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>

