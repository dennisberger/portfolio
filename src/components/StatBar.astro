---
/**
 * StatBar — horizontal row of stat value+label pairs.
 * Used at the top of case-study pages.
 */
interface Stat { value: string; label: string }
interface Props { stats: Stat[] }
const { stats } = Astro.props;
---

<dl class="stat-bar">
  {stats.map(s => (
    <div class="stat-bar__item">
      <dt class="stat-bar__label">{s.label}</dt>
      <dd class="stat-bar__value">{s.value}</dd>
    </div>
  ))}
</dl>

<style>
  .stat-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
    padding: var(--space-lg) 0;
    margin: 0;
  }
  .stat-bar__item {
    padding: 0 var(--space-lg);
    border-inline-start: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-2xs);
  }
  .stat-bar__item:first-child { border-inline-start: none; padding-inline-start: 0; }
  .stat-bar__value {
    font-family: var(--font-display);
    font-size: var(--type-2xl);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }
  .stat-bar__label {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
  }
</style>
