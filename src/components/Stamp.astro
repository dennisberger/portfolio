---
import SunFigure from './SunFigure.astro';

/**
 * Stamp — the signature mark.
 * CSS-rendered editorial imprint: text on a path around a circular figure.
 *
 * Props:
 *   size — overall diameter (default 160)
 *   variant — 'default' (fuchsia) or 'quiet' (muted ink)
 */
interface Props {
  size?: number;
  variant?: 'default' | 'quiet';
}

const { size = 160, variant = 'default' } = Astro.props;
---

<figure class={`stamp stamp--${variant}`} style={`--stamp-size: ${size}px;`} role="img" aria-label="Dennis Berger imprint — Philadelphia, MMXXVI">
  <svg class="stamp__rings" viewBox="0 0 200 200" aria-hidden="true" focusable="false">
    <defs>
      {/* Top arc: clockwise from 9 → 12 → 3 o'clock. Ascenders point outward. */}
      <path id="stamp-top-arc" d="M 20,100 A 80,80 0 0,1 180,100" />
      {/* Bottom arc: counter-clockwise from 9 → 6 → 3 o'clock at a slightly wider radius
          so the bottom text's visual midline matches the top's. Keeps bottom text right-side-up. */}
      <path id="stamp-bottom-arc" d="M 14,100 A 86,86 0 0,0 186,100" />
    </defs>
    <circle cx="100" cy="100" r="94" fill="none" stroke="currentColor" stroke-width="1" />
    <circle cx="100" cy="100" r="72" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4" />

    <text class="stamp__text stamp__text--top" aria-hidden="true">
      <textPath href="#stamp-top-arc" startOffset="50%" text-anchor="middle">
        DENNIS BERGER · OPERATOR · DESIGNER
      </textPath>
    </text>
    <text class="stamp__text stamp__text--bottom" aria-hidden="true">
      <textPath href="#stamp-bottom-arc" startOffset="50%" text-anchor="middle">
        PHILA · EST. MCMLXXXVI
      </textPath>
    </text>
  </svg>

  <div class="stamp__center">
    <slot><SunFigure /></slot>
  </div>
</figure>

<style>
  .stamp {
    display: inline-grid;
    place-items: center;
    width: var(--stamp-size, 160px);
    height: var(--stamp-size, 160px);
    position: relative;
    color: var(--color-fuchsia);
    margin: 0;
    /* Artful left-tilt — reads as hand-applied stamp rather than printed. */
    transform: rotate(-8deg);
    transform-origin: center;
    transition: transform 280ms var(--ease-out-quart);
  }
  /* Subtle press-harder tilt on hover — rewards the rare person who hovers
     a non-interactive mark. Gated on reduced-motion preference. */
  @media (prefers-reduced-motion: no-preference) {
    .stamp:hover {
      transform: rotate(-11deg);
    }
  }

  .stamp--quiet {
    color: var(--color-ink-dim);
  }

  .stamp__rings {
    grid-column: 1;
    grid-row: 1;
    width: 100%;
    height: 100%;
  }

  /* Text-on-path metrics calibrated at the reference 160px stamp size —
     9px / 0.2em top / 0.22em bottom fit the arc lengths of the two textPaths
     without clipping. These are part of the artwork, not the design system. */
  .stamp__text {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.2em;
    fill: currentColor;
    text-transform: uppercase;
  }
  .stamp__text--bottom { letter-spacing: 0.22em; }

  .stamp__center {
    grid-column: 1;
    grid-row: 1;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
</style>
