---
/**
 * MarginNote — voice aside in the right gutter.
 *
 * Layout inherited from `.gutter-aside` in global.css. This component owns
 * its identity: ※ marker, fuchsia accent, cobalt italic body.
 *
 * Desktop (≥1080px): floats into the right gutter.
 * Mobile: renders inline beneath the preceding paragraph.
 *
 * Usage in MDX:
 *   import MarginNote from '@/components/MarginNote.astro';
 *   <MarginNote>Ask boss. Don't panic. Eat tacos.</MarginNote>
 */
---

<aside class="gutter-aside margin-note">
  <span class="margin-note__marker" aria-hidden="true">※</span>
  <span class="margin-note__body"><slot /></span>
</aside>

<style>
  .margin-note {
    --gutter-aside-accent: var(--color-fuchsia);
    --gutter-aside-rule-top: calc(var(--type-base) * 1.2 + var(--space-2xs) + 0.15em);
    color: var(--color-cobalt-deep);
    font-style: italic;
  }

  .margin-note__marker {
    display: block;
    font-family: var(--font-display);
    font-size: var(--type-base);
    font-style: normal;
    line-height: 1;
    color: var(--color-fuchsia);
    margin-bottom: var(--space-2xs);
  }
</style>
