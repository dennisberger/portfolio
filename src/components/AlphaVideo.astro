---
// Cross-browser transparent video with play-once-on-scroll + reduced-motion
// fallback. Recipe: docs/alpha-video-for-web.md in ignyte.me.
//
// Asset pipeline:
//   - poster (PNG with alpha, imported from src/assets) → optimized to WebP
//     via getImage(). Single URL because HTML's `<video poster=>` attribute
//     can't point at a <picture>. WebP preserves alpha and is ~70% smaller
//     than the source PNG; universal modern-browser support.
//   - fallbackImg (PNG with alpha, imported from src/assets) → <Picture>
//     with AVIF/WebP/PNG sources. Shown only if <video> isn't supported at
//     all, but cheap to do right.
//   - videoSrc (string, file stem) → MP4 + WebM still served from /public:
//     - /${videoSrc}.mp4    HEVC + alpha (Safari)
//     - /${videoSrc}.webm   VP9 + alpha  (Chrome / Firefox / Edge)
//
// Source order for <video> children is load-bearing: MP4 first with
// codecs="hvc1" keeps Safari off the WebM (Safari's VP9 alpha renders black).

import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Imported PNG (alpha preserved) — first frame, used for `poster=`. */
  poster: ImageMetadata;
  /** Imported PNG (alpha preserved) — last frame, used for the <video> child <img> fallback. */
  fallbackImg: ImageMetadata;
  /** File stem under /public for the .mp4 + .webm pair, e.g. "effectv-mobile". */
  videoSrc: string;
  alt: string;
  width: number;
  height: number;
  /** IntersectionObserver threshold (0–1). Default 0.5. */
  threshold?: number;
}

const { poster, fallbackImg, videoSrc, alt, width, height, threshold = 0.5 } = Astro.props;

// Optimized WebP poster — preserves alpha, ~70% smaller than source PNG.
// Single URL (poster attr can't take <picture>). Pin to intrinsic width
// to match the video surface dimensions exactly (mismatched sizes flash).
const posterWebp = await getImage({
  src: poster,
  format: 'webp',
  width,
  quality: 90,
});
---

<video
  class="alpha-video"
  data-threshold={threshold}
  muted
  playsinline
  preload="auto"
  width={width}
  height={height}
  poster={posterWebp.src}
  aria-label={alt}
>
  <source src={`/${videoSrc}.mp4`} type='video/mp4; codecs="hvc1"' />
  <source src={`/${videoSrc}.webm`} type="video/webm" />
  <Picture
    src={fallbackImg}
    formats={['avif', 'webp']}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
  />
</video>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLVideoElement>('video.alpha-video').forEach((video) => {
    const threshold = Number(video.dataset.threshold) || 0.5;

    // Mobile Safari fix: seek to 0 on loadedmetadata so the browser renders
    // the first frame into the video surface *before* play() is ever called.
    // Without this, the poster→first-frame handoff creates a visible flash
    // on iOS, because mobile Safari tears down the poster surface before the
    // decoder has a frame to paint. Paired with preload="auto" this is clean.
    video.addEventListener('loadedmetadata', () => {
      try { video.currentTime = 0; } catch {}
    }, { once: true });

    // Keyboard-operable per WCAG 2.2.2 — user can pause/replay at will.
    video.tabIndex = 0;
    video.setAttribute('role', 'button');
    const toggle = () => {
      if (video.ended || video.paused) {
        video.currentTime = 0;
        video.play().catch(() => {});
      } else {
        video.pause();
      }
    };
    video.addEventListener('click', toggle);
    video.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        toggle();
      }
    });

    if (reduceMotion) return;

    const playFromStart = () => {
      try { video.currentTime = 0; } catch {}
      video.play().catch(() => {});
    };

    let hasPlayed = false;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasPlayed) {
            hasPlayed = true;
            video.play().catch(() => {});
          }
        });
      },
      { threshold }
    );
    io.observe(video);

    // Hover replays from start ONLY after the animation has already finished —
    // otherwise a cursor passing over the video mid-scroll resets currentTime
    // and produces a stutter. Touch devices skip hover and get clean play-once.
    video.addEventListener('mouseenter', () => {
      if (video.ended) playFromStart();
    });
  });
</script>

<style>
  .alpha-video {
    display: block;
    width: 100%;
    height: auto;
    cursor: pointer;
  }
  .alpha-video:focus-visible {
    outline: 2px solid var(--color-accent, currentColor);
    outline-offset: 4px;
  }
</style>
