---
/**
 * Footnote — numbered annotation in the right gutter.
 *
 * Layout inherited from `.gutter-aside` in global.css. This component owns
 * its identity: numeric marker, cobalt accent, muted-ink body. Intended for
 * source / method / caveat annotations on numeric claims — not voice asides
 * (use MarginNote for those).
 *
 * Usage in MDX:
 *   import Footnote from '@/components/Footnote.astro';
 *   <Footnote n={1}>Covers tooling, research partner, contractors.</Footnote>
 */
interface Props {
  n: number;
}
const { n } = Astro.props;
---

<aside class="gutter-aside footnote" role="doc-footnote">
  <span class="footnote__marker" aria-hidden="true">{n}</span>
  <span class="footnote__body"><slot /></span>
</aside>

<style>
  .footnote {
    --gutter-aside-accent: var(--color-cobalt);
    --gutter-aside-rule-top: calc(var(--type-lg) * 1 + var(--space-2xs) + 0.15em);
    color: var(--color-ink-muted);
  }

  .footnote__marker {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--type-lg);
    line-height: 1;
    color: var(--color-cobalt-deep);
    margin-bottom: var(--space-2xs);
  }
</style>
