---
/**
 * Footnote — a numbered annotation for numeric claims.
 *
 * Shares gutter positioning with MarginNote but uses a numeric marker instead
 * of the ※ glyph, and a cobalt register (substance) instead of fuchsia (voice).
 * Intended for source/method/caveat annotations on stats, not voice asides.
 *
 * Usage in MDX:
 *   import Footnote from '@/components/Footnote.astro';
 *   <Footnote n={1}>Covers tooling, research partner, contractors.</Footnote>
 */
interface Props {
  n: number;
}
const { n } = Astro.props;
---

<aside class="footnote" role="doc-footnote">
  <span class="footnote__marker" aria-hidden="true">{n}</span>
  <span class="footnote__body"><slot /></span>
</aside>

<style>
  .footnote {
    display: block;
    position: relative;
    margin-block: var(--space-md) var(--space-lg);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-paper-sunken);
    border-top: 1px solid var(--color-cobalt);
    font-family: var(--font-body);
    font-size: var(--type-sm);
    line-height: var(--leading-snug);
    color: var(--color-ink-muted);
  }

  .footnote__marker {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--type-lg);
    line-height: 1;
    color: var(--color-cobalt-deep);
    margin-bottom: var(--space-2xs);
  }

  /* Desktop: float into the right gutter like MarginNote */
  @media (min-width: 1080px) {
    .footnote {
      float: right;
      clear: right;
      width: var(--col-gutter);
      margin-right: calc(-1 * (var(--col-gutter) + var(--col-gap)));
      margin-top: 0.25em;
      margin-bottom: var(--space-md);
      background: transparent;
      border-top: none;
      padding-left: var(--space-lg);
      padding-right: 0;
    }

    .footnote::before {
      content: '';
      position: absolute;
      left: 0;
      top: calc(var(--type-lg) * 1 + var(--space-2xs) + 0.15em);
      width: var(--space-md);
      height: 1px;
      background: var(--color-cobalt);
    }
  }
</style>
