---
/**
 * LineChart — editorial trend chart for small-n data (3–6 points).
 *
 * Inline SVG, no library. Direct labels, no legend or axis ticks.
 * Optional `projected` flag makes the final segment dashed + fuchsia-accented.
 * Uses design tokens; respects prefers-reduced-motion (no animation yet).
 */
interface Point {
  label: string;
  value: number;
  /** Optional human-readable label for the value (e.g. "2 weeks" when value is 10 days). */
  display?: string;
}
interface Props {
  points: Point[];
  projected?: boolean;
  unit?: string;
  maxValue?: number;
  caption?: string;
  ariaLabel: string;
}
const { points, projected = false, unit = '', maxValue, caption, ariaLabel } = Astro.props;

const W = 520;
const H = 220;
const PAD_X = 36;
const PAD_Y_TOP = 34;
const PAD_Y_BOTTOM = 44;
const plotW = W - 2 * PAD_X;
const plotH = H - PAD_Y_TOP - PAD_Y_BOTTOM;
const n = points.length;
const max = maxValue ?? Math.max(1, ...points.map(p => p.value)) * 1.18;

const xOf = (i: number) => n === 1 ? W / 2 : PAD_X + (i * plotW) / (n - 1);
const yOf = (v: number) => PAD_Y_TOP + plotH - (v / max) * plotH;

const coords = points.map((p, i) => ({
  ...p,
  x: xOf(i),
  y: yOf(p.value),
  isLast: i === n - 1,
}));

const solidCount = projected ? n - 1 : n;
const solidPath = coords
  .slice(0, solidCount)
  .map((c, i) => (i === 0 ? `M ${c.x.toFixed(1)},${c.y.toFixed(1)}` : `L ${c.x.toFixed(1)},${c.y.toFixed(1)}`))
  .join(' ');
const dashPath =
  projected && n >= 2
    ? `M ${coords[n - 2].x.toFixed(1)},${coords[n - 2].y.toFixed(1)} L ${coords[n - 1].x.toFixed(1)},${coords[n - 1].y.toFixed(1)}`
    : '';
---

<figure class="linechart" data-reveal-chart>
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={ariaLabel}>
    {solidPath && <path class="linechart__line" pathLength="100" d={solidPath} fill="none" />}
    {dashPath && <path class="linechart__line linechart__line--projected" d={dashPath} fill="none" />}
    {coords.map((c, i) => (
      <g class="linechart__point" style={`--i:${i}`}>
        {projected && c.isLast && (
          <circle cx={c.x} cy={c.y} r="4.5" class="linechart__dot-pulse" />
        )}
        <circle
          cx={c.x}
          cy={c.y}
          r={projected && c.isLast ? 4.5 : 4}
          class={`linechart__dot${projected && c.isLast ? ' linechart__dot--projected' : ''}`}
        />
        <text x={c.x} y={c.y - 12} text-anchor="middle" class="linechart__value">
          {c.display ?? `${c.value}${unit}`}
        </text>
        <text x={c.x} y={H - 16} text-anchor="middle" class="linechart__xlabel">
          {c.label}
        </text>
      </g>
    ))}
  </svg>
  {caption && <figcaption class="linechart__caption">{caption}</figcaption>}
</figure>

<style>
  .linechart {
    margin: var(--space-2xl) 0;
    max-width: 520px;
  }
  .linechart svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }
  .linechart__line {
    stroke: var(--color-cobalt-deep);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .linechart__line--projected {
    stroke: var(--color-fuchsia-deep);
    stroke-dasharray: 4 5;
  }
  .linechart__dot {
    fill: var(--color-cobalt-deep);
  }
  .linechart__dot--projected {
    fill: var(--color-fuchsia-deep);
  }
  .linechart__value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    fill: var(--color-ink);
  }
  .linechart__xlabel {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    fill: var(--color-ink-muted);
  }
  .linechart__caption {
    margin-top: var(--space-sm);
    padding-left: 0;
    font-family: var(--font-body);
    font-size: var(--type-xs);
    color: var(--color-ink-muted);
    font-style: italic;
    max-width: 44ch;
  }

  /* Live pulse ring — rendered on the projected (dashed) final dot.
     Animates via `transform: scale()` (not SVG `r`) for reliable cross-browser
     behavior, and scales from 1 → 3.6 so the ring clearly emerges from beneath
     the solid dot rather than sitting atop it at identical size. */
  .linechart__dot-pulse {
    fill: var(--color-fuchsia-deep);
    opacity: 0.6;
    transform-box: fill-box;
    transform-origin: center;
    animation: projected-pulse 2.2s var(--ease-out-quart) infinite;
  }
  @keyframes projected-pulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    70%  { transform: scale(3.6); opacity: 0;   }
    100% { transform: scale(3.6); opacity: 0;   }
  }

  /* Scroll-reveal: line draws, points cascade, projected segment fades in last. */
  :global(.js-motion) .linechart[data-reveal-chart] .linechart__line {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  :global(.js-motion) .linechart[data-reveal-chart].is-visible .linechart__line {
    animation: chart-line-draw 900ms var(--ease-out-quart) forwards;
  }
  :global(.js-motion) .linechart[data-reveal-chart] .linechart__line--projected {
    opacity: 0;
    stroke-dasharray: 4 5;
    animation: none;
  }
  :global(.js-motion) .linechart[data-reveal-chart].is-visible .linechart__line--projected {
    animation: chart-line-dash-in 420ms var(--ease-out-quart) 820ms forwards;
  }
  :global(.js-motion) .linechart[data-reveal-chart] .linechart__point {
    opacity: 0;
    transform: translateY(4px);
  }
  :global(.js-motion) .linechart[data-reveal-chart].is-visible .linechart__point {
    animation: chart-point-in 460ms var(--ease-out-quart) forwards;
    animation-delay: calc(280ms + var(--i, 0) * 150ms);
  }

  @keyframes chart-line-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes chart-line-dash-in {
    to { opacity: 1; }
  }
  @keyframes chart-point-in {
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .linechart__dot-pulse { display: none; }
    :global(.js-motion) .linechart[data-reveal-chart] .linechart__line,
    :global(.js-motion) .linechart[data-reveal-chart] .linechart__line--projected,
    :global(.js-motion) .linechart[data-reveal-chart] .linechart__point {
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
